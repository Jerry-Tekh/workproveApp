# ─── WorkProof environment configuration ───────────────────────────────────
# Copy this file to .env.local and fill in the values.
# The deploy script writes .env.local automatically after a successful deploy.

# GenLayer network to connect to.
# For StudioNet deployment use: studionet
# Options: localnet | studionet | testnet-asimov | testnet-bradbury
NEXT_PUBLIC_GENLAYER_NETWORK=studionet

# The deployed WorkProof contract address.
# This is written automatically by the deploy script.
# Format: 0x followed by 40 hex characters
NEXT_PUBLIC_CONTRACT_ADDRESS=
